# Python bytecode — generated automatically, never commit
__pycache__/
*.py[cod]

# PyCharm IDE settings — personal to your machine
.idea/

# Trained model weights — can be large, regenerate with main.py
outputs/*.pth
# Keep the deployed model tracked so Streamlit Cloud can load it.
!outputs/brain_tumor_model.pth

# Generated plots — regenerated by running main.py
outputs/*.png

# OS files
.DS_Store
Thumbs.db

# Claude Code instructions — local only
CLAUDE.md
